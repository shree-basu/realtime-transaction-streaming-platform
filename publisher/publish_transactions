import random, uuid
from datetime import datetime, timezone

CURRENCIES = ["USD", "EUR", "GBP", "INR", "SGD"]
COUNTRIES  = ["US", "GB", "DE", "IN", "SG"]
CHANNELS   = ["POS", "ONLINE", "ATM"]
CATEGORIES = ["grocery", "travel", "electronics", "dining", "fuel", "cash"]
CUSTOMERS  = [f"CUST{n:04d}" for n in range(1, 51)]

def _good_event() -> dict:
    return {
        "transaction_id": str(uuid.uuid4()),
        "customer_id": random.choice(CUSTOMERS),
        "amount": round(random.uniform(1.0, 8000.0), 2),
        "currency": random.choice(CURRENCIES),
        "event_timestamp": datetime.now(timezone.utc).isoformat(),
        "merchant_id": f"M{random.randint(1000, 9999)}",
        "merchant_category": random.choice(CATEGORIES),
        "country": random.choice(COUNTRIES),
        "channel": random.choice(CHANNELS),
    }

def _bad_event() -> dict:
    """Break a rule so the dead-letter path can be exercised in dev."""
    broken = _good_event()
    choice = random.choice(["amount", "currency", "missing", "json"])
    if choice == "amount":
        broken["amount"] = -5.0
    elif choice == "currency":
        broken["currency"] = "XYZ"
    elif choice == "missing":
        broken.pop("customer_id")
    else:
        return {"__raw__": "this is not valid json at all"}
    return broken

import json
from google.cloud import pubsub_v1

def publish(project, topic, rate, duration, bad_fraction):
    batch = pubsub_v1.types.BatchSettings(max_messages=100, max_latency=0.1)
    publisher = pubsub_v1.PublisherClient(batch_settings=batch)
    topic_path = publisher.topic_path(project, topic)

    payload = _bad_event() if random.random() < bad_fraction else _good_event()
    if payload.get("__raw__"):
        data, attrs = payload["__raw__"].encode("utf-8"), {}
    else:
        data = json.dumps(payload).encode("utf-8")
        attrs = {"channel": str(payload.get("channel", "NA")),
                 "currency": str(payload.get("currency", "NA"))}
    publisher.publish(topic_path, data=data,
                      ordering_key=str(payload.get("customer_id", "")), **attrs)